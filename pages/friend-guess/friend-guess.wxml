<!-- 好友猜拳 -->
<view class="page">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹</text>
    <text class="nav-title">好友猜拳</text>
  </view>

  <view class="content">
    <view class="hint-text">请选择你要出的手势</view>

    <!-- 手势选择 -->
    <view class="gesture-selector">
      <view class="selector-item {{selected === 'rock' ? 'active' : ''}}" bindtap="onSelect" data-type="rock">
        <text class="selector-text">石头</text>
      </view>
      <view class="selector-item {{selected === 'scissors' ? 'active' : ''}}" bindtap="onSelect" data-type="scissors">
        <text class="selector-text">剪刀</text>
      </view>
      <view class="selector-item {{selected === 'paper' ? 'active' : ''}}" bindtap="onSelect" data-type="paper">
        <text class="selector-text">布</text>
      </view>
    </view>

    <!-- 手势显示 -->
    <view class="gesture-display">
      <text class="gesture-icon">{{gestureIcon}}</text>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-btn" bindtap="onShare">
      <text class="btn-icon">↗</text>
      <text>发送好友，让其挑战</text>
    </view>
  </view>
</view>
