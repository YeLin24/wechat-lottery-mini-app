.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 提示文字 */
.hint-text {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 32rpx;
}

/* 手势选择区域 */
.gesture-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid #409EFF;
  border-radius: 12rpx;
  padding: 16rpx;
}

.selector-item {
  flex: 1;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 32rpx 0;
  text-align: center;
  transition: all 0.3s;
}

.selector-item.active {
  background-color: #409EFF;
}

.selector-item.active .selector-text {
  color: #ffffff;
}

.selector-text {
  font-size: 28rpx;
  color: #333333;
}

/* 手势展示区域 */
.gesture-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.gesture-icon {
  font-size: 200rpx;
}

/* 底部按钮 */
.bottom-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.bottom-btn:active {
  opacity: 0.8;
}
