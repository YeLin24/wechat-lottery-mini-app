.page { min-height: 100vh; background-color: #f5f5f5; }
.nav-bar { background-color: #87CEEB; padding: 20rpx 30rpx; display: flex; align-items: center; justify-content: center; position: relative; }
.back-btn { position: absolute; left: 30rpx; font-size: 40rpx; color: #fff; }
.nav-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.content { padding: 30rpx; }
.hint-text { text-align: center; color: #87CEEB; font-size: 28rpx; margin-bottom: 40rpx; }
.gesture-area { display: flex; gap: 20rpx; justify-content: center; margin-bottom: 40rpx; }
.gesture-item { flex: 1; background-color: #fff; border-radius: 16rpx; padding: 40rpx 0; text-align: center; border: 3rpx solid transparent; }
.gesture-item.active { background-color: #1E90FF; border-color: #1E90FF; }
.gesture-item.active .gesture-text { color: #fff; }
.gesture-icon { font-size: 64rpx; display: block; margin-bottom: 10rpx; }
.gesture-text { font-size: 28rpx; color: #333; }
.result-area { text-align: center; margin: 30rpx 0; }
.result-text { font-size: 36rpx; font-weight: bold; color: #1E90FF; }
.action-area { display: flex; flex-direction: column; gap: 16rpx; }
.action-btn { background-color: #1E90FF; color: #fff; border-radius: 16rpx; padding: 24rpx 0; text-align: center; font-size: 28rpx; }
.action-btn.primary { font-weight: bold; }
.action-btn:active { opacity: 0.8; }
