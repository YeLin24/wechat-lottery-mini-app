<!-- 今天吃什么 -->
<view class="page">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">←</text>
    <text class="nav-title">今天吃什么</text>
  </view>
  <view class="content">
    <view class="hint-text">请点击开始</view>

    <!-- 结果展示 -->
    <view class="result-area" wx:if="{{result}}">
      <view class="result-food">{{result}}</view>
    </view>

    <view class="action-area">
      <view class="action-btn primary hand" bindtap="onPick">
        <text class="action-icon"> </text>
        <text>开始抽选</text>
      </view>
      <view class="action-btn" bindtap="onShareFriend">
        <text class="action-icon"> </text>
        <text>朋友帮选</text>
      </view>
      <view class="action-btn" bindtap="onTellFriend">
        <text class="action-icon"> </text>
        <text>告诉朋友吃什么</text>
      </view>
    </view>
  </view>
</view>
