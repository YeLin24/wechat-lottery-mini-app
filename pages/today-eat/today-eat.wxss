.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 计时器显示 */
.timer-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  width: fit-content;
  margin-bottom: 24rpx;
}

.timer-icon {
  font-size: 28rpx;
}

.timer-text {
  font-size: 24rpx;
  color: #00c853;
  font-family: monospace;
}

/* 提示文字 */
.hint-text {
  text-align: center;
  color: #666666;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* 结果展示 */
.result-area {
  display: flex;
  justify-content: center;
  margin: 32rpx 0;
}

.result-food {
  background-color: #409EFF;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 500;
  padding: 40rpx 60rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(64, 158, 255, 0.35);
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* 操作按钮区域 */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.action-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.action-btn:active {
  opacity: 0.8;
}

.btn-icon {
  font-size: 32rpx;
}
