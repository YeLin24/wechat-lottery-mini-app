.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 结果展示大卡片 */
.result-card {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
}

.result-title {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 500;
  text-align: center;
  margin-bottom: 24rpx;
}

.result-section {
  margin-bottom: 20rpx;
}

.result-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 8rpx;
}

.result-value {
  font-size: 32rpx;
  color: #ffffff;
  display: block;
  line-height: 1.6;
}

.result-value.unselected {
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

/* 配置区域 */
.config-area {
  margin-bottom: 32rpx;
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 28rpx;
  color: #333333;
  width: 160rpx;
}

.config-input {
  width: 200rpx;
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

/* 操作按钮区域 */
.button-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.button-row {
  display: flex;
  gap: 20rpx;
}

.button-row.single {
  justify-content: center;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.primary {
  background-color: #3a8ee6;
  font-weight: 500;
}

.button-row.single .action-btn {
  width: 60%;
  flex: none;
}

.share-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
}
