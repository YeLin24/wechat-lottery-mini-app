<!-- 随机数字抽签页面 -->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹</text>
    <text class="nav-title">随机数字抽签</text>
  </view>

  <view class="content">
    <!-- 顶部功能按钮 -->
    <view class="top-actions">
      <view class="top-action" bindtap="goToAdmin">
        <text class="action-icon">⚙</text>
        <text class="action-text">配置保存</text>
      </view>
      <view class="top-action" bindtap="openHistoryModal">
        <text class="action-icon">📋</text>
        <text class="action-text">查看历史</text>
      </view>
    </view>

    <!-- 结果展示大卡片 -->
    <view class="result-card">
      <view class="result-title">请生成随机数</view>
      <view class="result-number" wx:if="{{result !== null}}">{{result}}</view>
    </view>

    <!-- 配置区域 -->
    <view class="config-area">
      <view class="config-row">
        <text class="config-label">最小值:</text>
        <input class="config-input" type="number" value="{{minValue}}" bindinput="onMinInput" placeholder="0" />
      </view>
      <view class="config-row">
        <text class="config-label">最大值:</text>
        <input class="config-input" type="number" value="{{maxValue}}" bindinput="onMaxInput" placeholder="10" />
      </view>
      <view class="config-row">
        <text class="config-label">生成个数:</text>
        <input class="config-input" type="number" value="{{count}}" bindinput="onCountInput" placeholder="1" />
      </view>
      <view class="config-row">
        <text class="config-label">允许重复:</text>
        <switch checked="{{allowDuplicate}}" bindchange="onDuplicateChange" color="#409EFF" />
      </view>
    </view>

    <!-- 操作按钮区域 -->
    <view class="button-area">
      <view class="button-row">
        <view class="action-btn" bindtap="onReset">重置</view>
        <view class="action-btn primary" bindtap="onGenerate">生成</view>
      </view>
      <view class="button-row">
        <view class="action-btn" bindtap="onShareResult">分享结果</view>
        <view class="action-btn" bindtap="onCopyResult">复制结果</view>
      </view>
      <view class="button-row single">
        <view class="action-btn history-btn" bindtap="onClearHistory">
          <text class="btn-icon">↻</text>
          <text>历史去重</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史记录弹窗 -->
  <view class="modal-overlay" wx:if="{{showHistory}}" bindtap="closeHistory">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">历史记录 (共{{history.length}}条)</view>
      <scroll-view scroll-y class="history-list">
        <view class="history-item" wx:for="{{history}}" wx:key="index">
          <text class="history-time">{{item.time}}</text>
          <text class="history-number">{{item.number}}</text>
        </view>
        <view class="empty-tip" wx:if="{{history.length === 0}}">暂无记录</view>
      </scroll-view>
      <view class="modal-actions">
        <view class="modal-btn danger" bindtap="onClearHistory">清除记录</view>
        <view class="modal-btn" bindtap="closeHistory">关闭</view>
      </view>
    </view>
  </view>
</view>
