.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 顶部功能按钮 */
.top-actions {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
}

.top-action {
  display: flex;
  align-items: center;
  color: #409EFF;
  font-size: 28rpx;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.action-text {
  font-size: 28rpx;
}

/* 结果展示大卡片 */
.result-card {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.result-title {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.result-number {
  font-size: 100rpx;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 配置区域 */
.config-area {
  margin-bottom: 32rpx;
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 28rpx;
  color: #333333;
  width: 160rpx;
}

.config-input {
  width: 200rpx;
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

/* 操作按钮区域 */
.button-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.button-row {
  display: flex;
  gap: 20rpx;
}

.button-row.single {
  justify-content: center;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.primary {
  background-color: #3a8ee6;
  font-weight: 500;
}

.history-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.button-row.single .action-btn {
  width: 60%;
  flex: none;
}

/* 历史记录弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  color: #333333;
  margin-bottom: 24rpx;
}

.history-list {
  max-height: 500rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-time {
  font-size: 24rpx;
  color: #999999;
}

.history-number {
  font-size: 32rpx;
  color: #409EFF;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  color: #cccccc;
  padding: 40rpx 0;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 72rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.danger {
  background-color: #f56c6c;
}
