.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  background-color: #87CEEB;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.content {
  padding: 30rpx;
}

.hint-text {
  text-align: center;
  color: #87CEEB;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

/* 结果展示 */
.result-area {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.result-number {
  background-color: #1E90FF;
  color: #fff;
  font-size: 120rpx;
  font-weight: bold;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(30, 144, 255, 0.35);
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 配置区域 */
.config-area {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 30rpx;
  color: #333;
}

.config-input {
  width: 200rpx;
  text-align: right;
  font-size: 30rpx;
  color: #333;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 10rpx 16rpx;
}

/* 操作按钮 */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-row.single {
  justify-content: center;
}

.action-btn {
  flex: 1;
  background-color: #1E90FF;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.primary {
  background-color: #1678d1;
  font-weight: bold;
}

.action-row.single .action-btn {
  flex: none;
  width: 40%;
}

/* 点击次数信息 */
.click-info {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin-top: 30rpx;
}

/* 历史记录弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  border: 2rpx solid #1E90FF;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.history-list {
  max-height: 500rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-number {
  font-size: 32rpx;
  color: #1E90FF;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  color: #ccc;
  padding: 40rpx 0;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  background-color: #1E90FF;
  color: #fff;
  border-radius: 12rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.danger {
  background-color: #ff4d4f;
}
