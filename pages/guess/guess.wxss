.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 计时器和得分区域 */
.timer-score-area {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.timer-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.timer-icon {
  font-size: 32rpx;
}

.timer-text {
  font-size: 26rpx;
  color: #00c853;
  font-family: monospace;
}

.score-counters {
  display: flex;
  gap: 24rpx;
}

.score-counter {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.score-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.score-circle.correct {
  background-color: #00c853;
}

.score-circle.wrong {
  background-color: #ff1744;
}

.score-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.score-value.red {
  color: #ff1744;
}

/* 独角兽卡片 */
.unicorn-card {
  width: 100%;
  height: 400rpx;
  background-color: #409EFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.unicorn-icon {
  font-size: 200rpx;
}

/* 开始按钮 */
.start-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.start-btn:active {
  opacity: 0.8;
}

.btn-icon {
  font-size: 32rpx;
}
