<!-- 猜对错 -->
<view class="page">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹</text>
    <text class="nav-title">猜对错</text>
  </view>

  <view class="content">
    <!-- 计时器和得分 -->
    <view class="timer-score-area">
      <view class="timer-display">
        <text class="timer-icon">📞</text>
        <text class="timer-text">{{timerText}}</text>
      </view>
      <view class="score-counters">
        <view class="score-counter">
          <text class="score-circle correct">✓</text>
          <text class="score-value {{correctCount > 0 ? 'red' : ''}}">{{correctCount}}</text>
        </view>
        <view class="score-counter">
          <text class="score-circle wrong">✗</text>
          <text class="score-value {{wrongCount > 0 ? 'red' : ''}}">{{wrongCount}}</text>
        </view>
      </view>
    </view>

    <!-- 独角兽卡片 -->
    <view class="unicorn-card">
      <text class="unicorn-icon">🦄</text>
    </view>

    <!-- 开始按钮 -->
    <view class="start-btn" bindtap="onStart">
      <text class="btn-icon">✋</text>
      <text>{{running ? '正在猜...' : '点击开始'}}</text>
    </view>
  </view>
</view>
