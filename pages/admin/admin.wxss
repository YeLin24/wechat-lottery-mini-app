.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  background-color: #87CEEB;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.content {
  padding: 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

/* 配置卡片 */
.config-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 28rpx;
  color: #333;
}

.config-input {
  width: 150rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
  background-color: #f0f8ff;
  border: 2rpx solid #1E90FF;
  border-radius: 8rpx;
  padding: 10rpx 16rpx;
  margin: 0 10rpx;
}

/* 规则列表 */
.rules-list {
  margin-bottom: 30rpx;
}

.rule-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.rule-text {
  font-size: 28rpx;
  color: #333;
}

.highlight {
  color: #1E90FF;
  font-weight: bold;
  font-size: 34rpx;
}

.rule-delete {
  width: 50rpx;
  height: 50rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.rule-delete:active {
  opacity: 0.7;
}

.empty-rules {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 40rpx 0;
  background-color: #fff;
  border-radius: 12rpx;
}

/* 添加规则卡片 */
.add-rule-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.add-btn {
  background-color: #1E90FF;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.add-btn:active {
  opacity: 0.8;
}

/* 操作按钮 */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  background-color: #1E90FF;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.danger {
  background-color: #ff4d4f;
}

/* 状态卡片 */
.status-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.status-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #f8f8f8;
}

.status-value {
  color: #1E90FF;
  font-weight: bold;
}

/* 示例卡片 */
.example-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.json-area {
  width: 100%;
  height: 240rpx;
  font-size: 22rpx;
  color: #666;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.copy-btn {
  background-color: #1E90FF;
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 0;
  text-align: center;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.copy-btn:active {
  opacity: 0.8;
}
