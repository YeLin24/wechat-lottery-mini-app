<!-- 抽排序 -->
<view class="page">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹</text>
    <text class="nav-title">抽顺序</text>
  </view>

  <view class="content">
    <!-- 设置弹窗 -->
    <view class="modal-overlay" wx:if="{{showSetting}}" bindtap="closeSetting">
      <view class="modal-content" catchtap="stopPropagation">
        <view class="modal-title">设置</view>
        <view class="setting-row">
          <text class="setting-label">人数：</text>
          <input class="count-input" type="number" value="{{totalCount}}" bindinput="onCountInput" placeholder="请输入人数" />
        </view>
        <view class="modal-actions">
          <view class="modal-btn" bindtap="onConfirmSetting">确定</view>
          <view class="modal-btn cancel" bindtap="closeSetting">取消</view>
        </view>
      </view>
    </view>

    <!-- 标题 -->
    <view class="result-header" wx:if="{{started}}">
      <text class="result-title">抽卡排列顺序</text>
    </view>

    <!-- 卡片网格 -->
    <view class="card-grid" wx:if="{{started}}">
      <view class="card-item {{item.picked ? 'picked' : ''}}" wx:for="{{cards}}" wx:key="index" bindtap="onPickCard" data-index="{{index}}">
        <view class="card-inner" wx:if="{{!item.picked}}">
          <text class="card-icon">🦄</text>
        </view>
        <view class="card-inner picked" wx:else>
          <text class="card-number">{{item.number}}</text>
        </view>
      </view>
      <!-- 空位 -->
      <view class="card-item empty">
        <text class="empty-text">空</text>
      </view>
    </view>

    <!-- 开始按钮 -->
    <view class="start-area" wx:if="{{!started}}">
      <view class="action-btn primary" bindtap="onShowSetting">开始抽排序</view>
    </view>

    <!-- 重置按钮 -->
    <view class="action-area" wx:if="{{started}}">
      <view class="action-btn" bindtap="onReset">重置</view>
    </view>
  </view>
</view>
