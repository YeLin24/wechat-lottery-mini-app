.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 结果标题 */
.result-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

/* 卡片网格 */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 32rpx;
}

.card-item {
  width: 140rpx;
  height: 140rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.3);
  position: relative;
}

.card-item:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.card-item.picked {
  background-color: #f5f7fa;
}

.card-item.empty {
  background-color: #409EFF;
}

.card-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-icon {
  font-size: 64rpx;
}

.card-number {
  font-size: 48rpx;
  color: #409EFF;
  font-weight: bold;
}

.empty-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 开始区域 */
.start-area {
  display: flex;
  justify-content: center;
  margin-top: 200rpx;
}

.action-area {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.action-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  padding: 0 60rpx;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.primary {
  background-color: #3a8ee6;
  font-weight: 500;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  border: 2rpx solid #409EFF;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 24rpx;
  color: #333333;
}

.setting-row {
  padding: 24rpx 0;
}

.setting-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.count-input {
  width: 100%;
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

/* 弹窗按钮 */
.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 72rpx;
  background-color: #409EFF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.cancel {
  background-color: #f5f7fa;
  color: #666666;
}
