.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #409EFF 0%, #409EFF 30%, #ffffff 30%);
  padding-bottom: 40rpx;
}

/* 标题区域 */
.header {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.title {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 顶部功能 Tab */
.top-functions {
  display: flex;
  background-color: #ffffff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.top-function-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.function-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.function-text {
  font-size: 24rpx;
  color: #409EFF;
}

/* 功能卡片区域 */
.function-cards {
  padding: 20rpx 24rpx;
}

/* 大卡片 */
.card-large {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  border-radius: 16rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.3);
}

.card-corner {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.25);
  font-size: 20rpx;
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 0 16rpx 0 16rpx;
}

.card-corner.new {
  background: rgba(100, 200, 100, 0.4);
}

.card-icon {
  font-size: 64rpx;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.card-label {
  font-size: 28rpx;
  color: #ffffff;
}

/* 卡片行 */
.card-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

/* 中等卡片 */
.card-medium {
  flex: 1;
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  border-radius: 16rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.3);
}

.card-medium .card-icon {
  font-size: 56rpx;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.card-medium .card-label {
  font-size: 26rpx;
  color: #ffffff;
}

/* 小卡片列 */
.card-small-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-small {
  flex: 1;
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.3);
  min-width: 200rpx;
}

.card-small .card-icon {
  font-size: 40rpx;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.card-small .card-label {
  font-size: 24rpx;
  color: #ffffff;
}

/* 底部操作栏 */
.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.bottom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.3);
}

.bottom-btn:active {
  opacity: 0.8;
}

.bottom-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.bottom-btn text {
  font-size: 26rpx;
  color: #ffffff;
}

.bottom-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, #409EFF, transparent);
}
