.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #87CEEB 0%, #5BADE5 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: 40rpx;
}

/* 标题区域 */
.header {
  text-align: center;
  padding: 60rpx 0 30rpx;
}

.logo-area {
  margin-bottom: 16rpx;
}

.logo {
  width: 100rpx;
  height: 100rpx;
}

.title {
  font-size: 42rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* Tab导航栏 */
.tab-bar {
  display: flex;
  background-color: #fff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background-color: #1E90FF;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
}

/* 功能按钮网格 */
.function-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx;
  gap: 20rpx;
  justify-content: center;
}

.function-btn {
  width: calc(33.33% - 14rpx);
  background-color: #1E90FF;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(30, 144, 255, 0.3);
}

.function-btn:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.btn-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.btn-label {
  font-size: 24rpx;
  color: #fff;
}

/* 底部操作栏 */
.bottom-bar {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  margin-top: auto;
}

.bottom-btn {
  flex: 1;
  background-color: #1E90FF;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 144, 255, 0.25);
}

.bottom-btn:active {
  opacity: 0.8;
}

.bottom-icon {
  font-size: 32rpx;
}
