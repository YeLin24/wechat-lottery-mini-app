.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 设置标题 */
.settings-title {
  text-align: center;
  font-size: 32rpx;
  color: #409EFF;
  font-weight: 500;
  margin-bottom: 32rpx;
}

/* 设置面板 */
.settings-panel {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  border: 2rpx solid #e0e0e0;
}

.setting-group {
  margin-bottom: 32rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

/* 复选框选项 */
.checkbox-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #cccccc;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.checkbox.checked {
  background-color: #409EFF;
  border-color: #409EFF;
}

.checkbox.checked::after {
  content: '✓';
}

/* 切换按钮 */
.toggle-options {
  display: flex;
  gap: 16rpx;
}

.toggle-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666666;
}

.toggle-btn.active {
  background-color: #409EFF;
  color: #ffffff;
}

.toggle-btn:active {
  opacity: 0.8;
}

/* 确认按钮 */
.confirm-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  margin-top: 32rpx;
}

.confirm-btn:active {
  opacity: 0.8;
}
