.page { min-height: 100vh; background-color: #f5f5f5; }
.nav-bar { background-color: #87CEEB; padding: 20rpx 30rpx; display: flex; align-items: center; justify-content: center; position: relative; }
.back-btn { position: absolute; left: 30rpx; font-size: 40rpx; color: #fff; }
.nav-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.content { padding: 30rpx; display: flex; flex-direction: column; align-items: center; }
.bottle-area { margin: 60rpx 0; }
.bottle { width: 120rpx; height: 200rpx; position: relative; transition: transform 0.1s linear; }
.bottle.spinning { animation: spin 0.5s linear infinite; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
.bottle-body { width: 80rpx; height: 160rpx; background: linear-gradient(135deg, #ff9966, #ff6633); border-radius: 10rpx 10rpx 20rpx 20rpx; position: absolute; bottom: 0; left: 20rpx; }
.bottle-neck { width: 30rpx; height: 40rpx; background: linear-gradient(135deg, #ff9966, #ff6633); position: absolute; top: -38rpx; left: 25rpx; border-radius: 5rpx 5rpx 0 0; }
.bottle-tip { width: 0; height: 0; border-left: 15rpx solid transparent; border-right: 15rpx solid transparent; border-bottom: 20rpx solid #ff6633; position: absolute; top: -58rpx; left: 25rpx; }
.action-btn { background-color: #1E90FF; color: #fff; border-radius: 16rpx; padding: 28rpx 80rpx; text-align: center; font-size: 30rpx; margin-bottom: 40rpx; }
.action-btn.primary { font-weight: bold; }
.action-btn:active { opacity: 0.8; }
.rules-text { font-size: 24rpx; color: #999; line-height: 1.8; text-align: center; padding: 0 20rpx; }
