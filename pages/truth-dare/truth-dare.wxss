.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 瓶子区域 */
.bottle-area {
  margin: 60rpx 0 48rpx;
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottle {
  position: relative;
  width: 120rpx;
  height: 200rpx;
  transition: transform 3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.bottle.spinning {
  animation: spin 0.5s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 瓶身 */
.bottle-body {
  position: absolute;
  bottom: 0;
  left: 20rpx;
  width: 80rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ffb366 0%, #ff9933 100%);
  border-radius: 8rpx 8rpx 16rpx 16rpx;
}

/* 标签 */
.bottle-label {
  position: absolute;
  bottom: 40rpx;
  left: 24rpx;
  width: 72rpx;
  height: 60rpx;
  background-color: #409EFF;
  border-radius: 4rpx;
}

.bottle-label::after {
  content: '💫';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
}

/* 瓶颈 */
.bottle::before {
  content: '';
  position: absolute;
  top: 40rpx;
  left: 45rpx;
  width: 30rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #ffb366 0%, #ff9933 100%);
  border-radius: 4rpx 4rpx 0 0;
}

/* 瓶盖 */
.bottle-cap {
  position: absolute;
  top: 0;
  left: 42rpx;
  width: 36rpx;
  height: 20rpx;
  background-color: #409EFF;
  border-radius: 4rpx 4rpx 0 0;
}

/* 开始按钮 */
.action-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 32rpx;
  padding: 0 80rpx;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.primary {
  background-color: #3a8ee6;
  font-weight: 500;
}

/* 规则文字 */
.rules-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
  text-align: center;
  padding: 0 32rpx;
}
