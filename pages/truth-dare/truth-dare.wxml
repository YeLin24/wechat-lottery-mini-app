<!-- 真心话大冒险 -->
<view class="page">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹</text>
    <text class="nav-title">真心话大冒险</text>
  </view>

  <view class="content">
    <!-- 瓶子插图 -->
    <view class="bottle-area">
      <view class="bottle {{spinning ? 'spinning' : ''}}" style="transform: rotate({{rotation}}deg);">
        <view class="bottle-cap"></view>
        <view class="bottle-label"></view>
        <view class="bottle-body"></view>
      </view>
    </view>

    <!-- 开始按钮 -->
    <view class="action-btn primary" bindtap="onSpin">
      {{spinning ? '正在转动...' : '开始转动'}}
    </view>

    <!-- 玩法规则 -->
    <view class="rules-text">
      玩法：点击转动按钮，待瓶子停止转动后，瓶口对准谁，谁就是被抽到的人。抽到的人可选择要真心话还是大冒险。
    </view>
  </view>
</view>
