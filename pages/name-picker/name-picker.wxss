.page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部导航栏 */
.nav-bar {
  background-color: #409EFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
}

.content {
  padding: 24rpx;
}

/* 模式按钮 */
.mode-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.mode-btn {
  height: 120rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #ffffff;
  font-size: 32rpx;
}

.mode-btn:active {
  opacity: 0.8;
}

.mode-icon {
  font-size: 40rpx;
}

/* 结果展示区域 */
.result-area {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0;
}

.result-number {
  width: 300rpx;
  height: 300rpx;
  background-color: #409EFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  color: #ffffff;
  font-weight: bold;
  box-shadow: 0 10rpx 40rpx rgba(64, 158, 255, 0.4);
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* 操作按钮区域 */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  height: 88rpx;
  background-color: #409EFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.primary {
  background-color: #3a8ee6;
  font-weight: 500;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  border: 2rpx solid #409EFF;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 24rpx;
  color: #333333;
}

.setting-row {
  padding: 16rpx 0;
}

.setting-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

/* 自定义名单输入 */
.input-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
}

.add-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #409EFF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
}

/* 名字列表 */
.name-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
  min-height: 60rpx;
  padding: 16rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
}

.name-chip {
  background-color: #409EFF;
  color: #ffffff;
  border-radius: 6rpx;
  padding: 10rpx 16rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.remove-btn {
  font-size: 20rpx;
  opacity: 0.8;
}

.empty-text {
  color: #999999;
  font-size: 26rpx;
}

/* 弹窗按钮 */
.modal-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 72rpx;
  background-color: #409EFF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.cancel {
  background-color: #f5f7fa;
  color: #666666;
}
