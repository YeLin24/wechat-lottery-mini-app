/* 全局样式 */
page {
  background-color: #87CEEB;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 公共导航栏样式 */
.nav-bar {
  background-color: #87CEEB;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-bar .back-btn {
  position: absolute;
  left: 30rpx;
  font-size: 40rpx;
  color: #fff;
}

.nav-bar .nav-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

/* 公共按钮样式 */
.btn-primary {
  background-color: #1E90FF;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 公共输入框样式 */
.input-box {
  background-color: #fff;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

/* 结果数字显示 */
.result-number {
  background-color: #1E90FF;
  color: #fff;
  font-size: 120rpx;
  font-weight: bold;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx auto;
  box-shadow: 0 8rpx 30rpx rgba(30, 144, 255, 0.3);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  border: 2rpx solid #1E90FF;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}
